{
  "name": "advanced-terminal",
  "productName": "Advanced Terminal",
  "version": "0.2.1",
  "description": "Менеджер именованных bash-терминалов с привязкой сессий Claude Code",
  "main": "out/main/index.js",
  "private": true,
  "license": "MIT",
  "author": "armeny007",
  "homepage": "https://github.com/armeny007/advanced-terminal",
  "repository": {
    "type": "git",
    "url": "https://github.com/armeny007/advanced-terminal.git"
  },
  "keywords": [
    "electron",
    "terminal",
    "claude-code",
    "xterm",
    "node-pty"
  ],
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "dist": "electron-vite build && electron-builder --mac"
  },
  "build": {
    "appId": "dev.armen.advanced-terminal",
    "productName": "Advanced Terminal",
    "files": [
      "out/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "build/icon.icns"
    }
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/xterm": "^6.0.0",
    "node-pty": "^1.1.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "typescript": "^6.0.3",
    "vite": "^6.4.3"
  }
}
